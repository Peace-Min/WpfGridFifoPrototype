<Project Sdk="Microsoft.NET.Sdk.WindowsDesktop">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net472</TargetFramework>
    <UseWPF>true</UseWPF>
    <RootNamespace>WpfGridFifoPrototype</RootNamespace>
    <AssemblyName>WpfGridFifoPrototype</AssemblyName>
    <AutoGenerateBindingRedirects>true</AutoGenerateBindingRedirects>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="DevExpress.Wpf.Grid" Version="25.1.*" />
    <PackageReference Include="DevExpress.Wpf.Core" Version="25.1.*" />
    <PackageReference Include="DevExpress.Mvvm" Version="25.1.*" />
    <Reference Include="System.Web" />
    <Reference Include="System.Configuration" />
  </ItemGroup>

</Project>
