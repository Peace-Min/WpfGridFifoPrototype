<Window x:Class="WpfGridFifoPrototype.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
        xmlns:vm="clr-namespace:WpfGridFifoPrototype.ViewModels"
        xmlns:views="clr-namespace:WpfGridFifoPrototype.Views"
        Title="WPF TargetGrid Prototype"
        Width="1380"
        Height="760"
        Background="#F8FAFC">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <Style x:Key="AddButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#EFF6FF" />
            <Setter Property="Foreground" Value="#2563EB" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2563EB" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="28">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="340" />
            <ColumnDefinition Width="24" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="White"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                CornerRadius="12"
                Padding="20">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                    <TextBlock FontSize="18" FontWeight="Bold" Foreground="#0F172A" Text="Source Data" />
                    <TextBlock Margin="0,4,0,0" Foreground="#64748B" Text="소스 항목을 선택한 축에 채웁니다." />
                </StackPanel>

                <dxg:GridControl ItemsSource="{Binding SourceItems}" ShowBorder="False">
                    <dxg:GridControl.View>
                        <dxg:TableView ShowGroupPanel="False"
                                       ShowIndicator="False"
                                       AllowEditing="False"
                                       NavigationStyle="Row"
                                       AutoWidth="True" />
                    </dxg:GridControl.View>

                    <dxg:GridColumn FieldName="ObjectLabel" Header="객체명" Width="110" />
                    <dxg:GridColumn FieldName="AttributeLabel" Header="속성명" Width="110" />
                    <dxg:GridColumn FieldName="Unit" Header="단위" Width="55" />
                    <dxg:GridColumn Header="추가" Width="55" HorizontalHeaderContentAlignment="Center">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="+"
                                        Style="{StaticResource AddButtonStyle}"
                                        Command="{Binding DataContext.AddToTargetCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding RowData.Row}" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                </dxg:GridControl>
            </DockPanel>
        </Border>

        <Border Grid.Column="2"
                Background="White"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                CornerRadius="12"
                Padding="20">
            <DockPanel>
                <Grid DockPanel.Dock="Top" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock FontSize="18" FontWeight="Bold" Foreground="#0F172A" Text="Target Grid" />
                        <Border Margin="16,0,0,0"
                                Padding="6,3"
                                Background="#F1F5F9"
                                CornerRadius="4">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock VerticalAlignment="Center" Foreground="#64748B" Text="차원: " />
                                <ComboBox Width="60"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          ItemsSource="{Binding ModeOptions}"
                                          SelectedItem="{Binding TargetGrid.DimensionMode}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Margin="0,0,8,0"
                                Padding="12,5"
                                Background="#ECFDF5"
                                BorderBrush="#10B981"
                                BorderThickness="1"
                                Command="{Binding TargetGrid.AddTargetRowCommand}"
                                Content="+ 로우" />
                        <Button Margin="0,0,8,0"
                                Padding="12,5"
                                Background="#FFF1F2"
                                BorderBrush="#F43F5E"
                                BorderThickness="1"
                                Command="{Binding TargetGrid.RemoveSelectedTargetRowCommand}"
                                Content="선택 로우 삭제" />
                        <Button Padding="12,5"
                                Background="#DBEAFE"
                                BorderBrush="#3B82F6"
                                BorderThickness="1"
                                Command="{Binding ValidateCommand}"
                                Content="검증" />
                    </StackPanel>
                </Grid>

                <Grid DockPanel.Dock="Bottom" Margin="0,16,0,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Foreground="#64748B" Text="선택 Row: " />
                        <TextBlock FontWeight="Bold" Foreground="#0F172A" Text="{Binding TargetGrid.SelectedTargetRow.GroupTitle}" />
                        <TextBlock Margin="16,0,0,0" Foreground="#64748B" Text="선택 Detail: " />
                        <TextBlock FontWeight="Bold" Foreground="#0F172A" Text="{Binding TargetGrid.SelectedDetail.RoleLabel}" />
                        <TextBlock Margin="16,0,0,0" Foreground="#64748B" Text="속성: " />
                        <TextBlock FontWeight="Bold" Foreground="#0F172A" Text="{Binding TargetGrid.SelectedDetail.AttributeLabel}" />
                    </StackPanel>
                </Grid>

                <views:TargetGridView DataContext="{Binding TargetGrid}" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
