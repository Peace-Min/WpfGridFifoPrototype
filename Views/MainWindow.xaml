<Window x:Class="WpfGridFifoPrototype.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
        xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
        xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
        xmlns:vm="clr-namespace:WpfGridFifoPrototype.ViewModels"
        xmlns:converters="clr-namespace:System.Windows.Controls;assembly=PresentationFramework"
        Title="WPF GridControl Add-Only Prototype" Height="600" Width="1100"
        Background="#F9FAFB">
    
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        


        <!-- 개별 필드 슬롯 템플릿 -->
        <DataTemplate x:Key="DetailSlotTemplate">
            <Grid>
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                                <Setter Property="Opacity" Value="0.3"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/> <!-- 이동 버튼 컬럼 -->
                    <ColumnDefinition Width="*"/>    <!-- 텍스트 컬럼 -->
                    <ColumnDefinition Width="Auto"/> <!-- 삭제 버튼 컬럼 -->
                </Grid.ColumnDefinitions>
                
                <!-- 하위 로우 내 이동 버튼 -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,0">
                    <Button Content="▲" FontSize="8" Width="18" Height="14" Padding="0" Margin="0,0,0,1" 
                            Background="#F8FAFC" BorderBrush="#E2E8F0" Foreground="#64748B"
                            Command="{Binding DataContext.MoveDetailUpCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}"
                            Visibility="{Binding CanMoveUp, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <Button Content="▼" FontSize="8" Width="18" Height="14" Padding="0" 
                            Background="#F8FAFC" BorderBrush="#E2E8F0" Foreground="#64748B"
                            Command="{Binding DataContext.MoveDetailDownCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}"
                            Visibility="{Binding CanMoveDown, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Y}" FontWeight="Bold" Foreground="#1E293B" FontSize="11"/>
                    <TextBlock Text="{Binding Attr}" Foreground="#64748B" FontSize="10" TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <Button Grid.Column="2" Content="✕" Background="Transparent" BorderThickness="0" Foreground="#CBD5E1"
                        Command="{Binding DataContext.RemoveDetailCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="{Binding}"
                        Visibility="{Binding IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="#EF4444"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </DataTemplate>
        <!-- HTML 스타일의 버튼 테마 재현 -->
        <Style x:Key="AddButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#EFF6FF"/>
            <Setter Property="Foreground" Value="#2563EB"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3B82F6"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 선택된 Target Row 강조 스타일 -->
        <Style x:Key="TargetRowStyle" TargetType="dxg:RowControl">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="#ECFDF5"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="40">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="4*"/>
            <ColumnDefinition Width="40"/>
            <ColumnDefinition Width="6*"/>
        </Grid.ColumnDefinitions>

        <!-- Source 리스트 -->
        <Border Grid.Column="0" Background="White" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.05"/>
            </Border.Effect>
            <DockPanel Margin="24">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,16">
                    <Border Background="#3B82F6" Width="8" Height="24" CornerRadius="2" Margin="0,0,8,0"/>
                    <TextBlock Text="데이터 리스트 (Source)" FontSize="18" FontWeight="Bold" Foreground="#1E293B"/>
                </StackPanel>

                <dxg:GridControl ItemsSource="{Binding SourceItems}" ShowBorder="False">
                    <dxg:GridControl.View>
                        <dxg:TableView ShowGroupPanel="False" AllowEditing="False"
                                       HeaderPanelMinHeight="40" RowMinHeight="45">
                            <dxg:TableView.ColumnHeaderStyle>
                                <Style TargetType="dxg:BaseGridHeader">
                                    <Setter Property="Background" Value="#F8FAFC"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </dxg:TableView.ColumnHeaderStyle>
                        </dxg:TableView>
                    </dxg:GridControl.View>

                    <dxg:GridColumn FieldName="Name" Header="이름 (Y)" Width="100"/>
                    <dxg:GridColumn FieldName="Attr" Header="속성" Width="*"/>
                    <dxg:GridColumn Header="추가" Width="60" HorizontalHeaderContentAlignment="Center">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="+" Style="{StaticResource AddButtonStyle}"
                                        Command="{Binding View.DataContext.AddToTargetCommand}"
                                        CommandParameter="{Binding RowData.Row}"/>
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                </dxg:GridControl>
            </DockPanel>
        </Border>

        <!-- Target 리스트 -->
        <Border Grid.Column="2" Background="White" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.05"/>
            </Border.Effect>
            <DockPanel Margin="24">
                <Grid DockPanel.Dock="Top" Margin="0,0,0,16">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <Border Background="#10B981" Width="8" Height="24" CornerRadius="2" Margin="0,0,8,0"/>
                        <TextBlock Text="RMSS 모니터링 (Target)" FontSize="18" FontWeight="Bold" Foreground="#1E293B"/>
                        
                        <!-- 차원 선택 (2D/3D) -->
                        <Border Margin="16,0,0,0" Background="#F1F5F9" CornerRadius="4" Padding="4,2">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="모드: " VerticalAlignment="Center" FontSize="11" Foreground="#64748B"/>
                                <ComboBox ItemsSource="{Binding ModeOptions}" SelectedItem="{Binding DimensionMode}" Width="60" Height="22" FontSize="11" BorderThickness="0" Background="Transparent"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    
                    <Button Content="+ 로우 추가" HorizontalAlignment="Right" Padding="12,4" 
                            Command="{Binding AddTargetRowCommand}"
                            Background="#ECFDF5" Foreground="#059669" BorderBrush="#10B981" BorderThickness="1">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>

                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,16,0,0">
                    <Ellipse Fill="#34D399" Width="12" Height="12" Margin="0,0,8,0"/>
                    <TextBlock Text="현재 선택된 순번: " FontSize="11" Foreground="#94A3B8"/>
                    <TextBlock Text="{Binding SelectedTargetRow.No, StringFormat={}{0}번}" FontSize="11" FontWeight="Bold" Foreground="#475569"/>
                    <TextBlock Text=" (리스트에서 + 클릭 시 여기로 추가됨)" FontSize="11" Foreground="#94A3B8"/>
                </StackPanel>

                <dxg:GridControl ItemsSource="{Binding TargetRows}" 
                                 SelectedItem="{Binding SelectedTargetRow}"
                                 ShowBorder="False">
                    <dxg:GridControl.View>
                        <dxg:TableView ShowGroupPanel="False" AllowEditing="False"
                                       RowStyle="{StaticResource TargetRowStyle}"
                                       HeaderPanelMinHeight="40" RowMinHeight="100">
                        </dxg:TableView>
                    </dxg:GridControl.View>

                    <dxg:GridControl.Bands>
                        <!-- 순번 밴드 -->
                        <dxg:GridControlBand Header=" " HorizontalHeaderContentAlignment="Center">
                            <dxg:GridColumn FieldName="No" Header="순번" Width="50" HorizontalHeaderContentAlignment="Center">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Value}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="#475569"/>
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                        </dxg:GridControlBand>

                        <!-- 레이블 밴드 -->
                        <dxg:GridControlBand Header=" " HorizontalHeaderContentAlignment="Center">
                            <dxg:GridColumn FieldName="Label" Header="레이블" Width="100">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Value}" VerticalAlignment="Center" Margin="4,0"/>
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                        </dxg:GridControlBand>

                        <!-- 그룹 정보 밴드 (요청하신 부분) -->
                        <dxg:GridControlBand Header="그룹 정보" HorizontalHeaderContentAlignment="Center">
                            <dxg:GridColumn Header="?" Width="40" HorizontalHeaderContentAlignment="Center">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <ItemsControl ItemsSource="{Binding RowData.Row.Details}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#F1F5F9" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="4" Margin="0,2" Height="26">
                                                        <TextBlock Text="{Binding RoleLabel}" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding RoleLabel}" Value="X"> <Setter Property="Foreground" Value="#3B82F6"/> </DataTrigger>
                                                                        <DataTrigger Binding="{Binding RoleLabel}" Value="Y"> <Setter Property="Foreground" Value="#F43F5E"/> </DataTrigger>
                                                                        <DataTrigger Binding="{Binding RoleLabel}" Value="Z"> <Setter Property="Foreground" Value="#10B981"/> </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                            
                            <dxg:GridColumn Header="라벨명" Width="*">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <ItemsControl ItemsSource="{Binding RowData.Row.Details}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#F1F5F9" BorderBrush="#CBD5E1" BorderThickness="1,1,0,1" Margin="0,2" Padding="6,0" Height="26">
                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Y}" FontWeight="Bold" Foreground="#1E293B" FontSize="11" Margin="0,0,8,0"/>
                                                            <TextBlock Text="{Binding Attr}" Foreground="#64748B" FontSize="10" TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>

                            <dxg:GridColumn Header="단위" Width="50" HorizontalHeaderContentAlignment="Center">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <ItemsControl ItemsSource="{Binding RowData.Row.Details}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#F1F5F9" BorderBrush="#CBD5E1" BorderThickness="0,1,1,1" CornerRadius="0,4,4,0" Margin="0,2" Height="26">
                                                        <Button Content="✕" Background="Transparent" BorderThickness="0" Foreground="#CBD5E1"
                                                            Command="{Binding DataContext.RemoveDetailCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Visibility="{Binding IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}"
                                                            Cursor="Hand" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                            <Button.Style>
                                                                <Style TargetType="Button">
                                                                    <Style.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter Property="Foreground" Value="#EF4444"/>
                                                                        </Trigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                        </Button>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                        </dxg:GridControlBand>

                        <!-- 상태 및 삭제 밴드 -->
                        <dxg:GridControlBand Header=" " HorizontalHeaderContentAlignment="Center">
                            <dxg:GridColumn FieldName="Color" Header="상태/성상" Width="100" HorizontalHeaderContentAlignment="Center">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,4" Padding="8,4" CornerRadius="4" HorizontalAlignment="Center" VerticalAlignment="Center" BorderThickness="1">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Value}" Value="Active">
                                                            <Setter Property="Background" Value="#ECFDF5"/>
                                                            <Setter Property="BorderBrush" Value="#10B981"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Value}" Value="Standby">
                                                            <Setter Property="Background" Value="#FFF1F2"/>
                                                            <Setter Property="BorderBrush" Value="#F43F5E"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Value}" FontSize="11" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Value}" Value="Active">
                                                                <Setter Property="Foreground" Value="#059669"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Value}" Value="Standby">
                                                                <Setter Property="Foreground" Value="#E11D48"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                        </dxg:GridControlBand>

                        <!-- 삭제 버튼 밴드 -->
                        <dxg:GridControlBand Header=" " HorizontalHeaderContentAlignment="Center">
                            <dxg:GridColumn Header="삭제" Width="50" HorizontalHeaderContentAlignment="Center">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="🗑" Background="Transparent" BorderThickness="0" Foreground="#94A3B8" FontSize="14"
                                                Command="{Binding View.DataContext.DeleteTargetRowCommand}"
                                                CommandParameter="{Binding RowData.Row}"
                                                VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Foreground" Value="#EF4444"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                        </dxg:GridControlBand>
                    </dxg:GridControl.Bands>


                </dxg:GridControl>
            </DockPanel>
        </Border>
    </Grid>
</Window>
