<Window x:Class="WpfGridFifoPrototype.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
        xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
        xmlns:vm="clr-namespace:WpfGridFifoPrototype.ViewModels"
        Title="WPF GridControl Add-Only Prototype"
        Width="1180"
        Height="680"
        Background="#F9FAFB">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="AddButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#EFF6FF" />
            <Setter Property="Foreground" Value="#2563EB" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3B82F6" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TargetRowStyle" TargetType="dxg:RowControl">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="#ECFDF5" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RoleTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#475569" />
            <Setter Property="FontWeight" Value="Bold" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding RoleLabel}" Value="X">
                    <Setter Property="Foreground" Value="#2563EB" />
                </DataTrigger>
                <DataTrigger Binding="{Binding RoleLabel}" Value="Y">
                    <Setter Property="Foreground" Value="#E11D48" />
                </DataTrigger>
                <DataTrigger Binding="{Binding RoleLabel}" Value="Z">
                    <Setter Property="Foreground" Value="#059669" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DetailCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Opacity" Value="1" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                    <Setter Property="Opacity" Value="0.55" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="#DBEAFE" />
                    <Setter Property="BorderBrush" Value="#2563EB" />
                    <Setter Property="Opacity" Value="1" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="DetailSlotTemplate">
            <Border Margin="0,3"
                    Padding="8,6"
                    Cursor="Hand"
                    Style="{StaticResource DetailCardStyle}">
                <dxmvvm:Interaction.Behaviors>
                    <dxmvvm:EventToCommand EventName="PreviewMouseLeftButtonDown"
                                           Command="{Binding DataContext.SelectDetailCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                           CommandParameter="{Binding}" />
                </dxmvvm:Interaction.Behaviors>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center">
                        <Button Content="^"
                                Width="18"
                                Height="14"
                                Margin="0,0,0,2"
                                Padding="0"
                                Background="#F8FAFC"
                                BorderBrush="#CBD5E1"
                                Foreground="#64748B"
                                Command="{Binding DataContext.MoveDetailUpCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"
                                Visibility="{Binding CanMoveUp, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <Button Content="v"
                                Width="18"
                                Height="14"
                                Padding="0"
                                Background="#F8FAFC"
                                BorderBrush="#CBD5E1"
                                Foreground="#64748B"
                                Command="{Binding DataContext.MoveDetailDownCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"
                                Visibility="{Binding CanMoveDown, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>

                    <Border Grid.Column="1"
                            Width="34"
                            Height="24"
                            Margin="0,0,8,0"
                            Background="White"
                            BorderBrush="#CBD5E1"
                            BorderThickness="1"
                            CornerRadius="4"
                            VerticalAlignment="Center">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Text="{Binding RoleLabel}"
                                   Style="{StaticResource RoleTextStyle}" />
                    </Border>

                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Y, TargetNullValue=(empty)}"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="#1E293B" />
                        <TextBlock Text="{Binding Attr, TargetNullValue=Select a source item}"
                                   FontSize="10"
                                   Foreground="#64748B"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>

                    <Button Grid.Column="3"
                            Width="24"
                            Height="24"
                            Margin="8,0,0,0"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="#94A3B8"
                            FontWeight="Bold"
                            Content="x"
                            Command="{Binding DataContext.RemoveDetailCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="#DC2626" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="40">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="4*" />
            <ColumnDefinition Width="32" />
            <ColumnDefinition Width="6*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="White"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                CornerRadius="12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.05" />
            </Border.Effect>

            <DockPanel Margin="24">
                <StackPanel DockPanel.Dock="Top"
                            Orientation="Horizontal"
                            Margin="0,0,0,16">
                    <Border Width="8"
                            Height="24"
                            Margin="0,0,8,0"
                            Background="#3B82F6"
                            CornerRadius="2" />
                    <TextBlock Text="Source"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#1E293B" />
                </StackPanel>

                <dxg:GridControl ItemsSource="{Binding SourceItems}" ShowBorder="False">
                    <dxg:GridControl.View>
                        <dxg:TableView ShowGroupPanel="False"
                                       AllowEditing="False"
                                       HeaderPanelMinHeight="40"
                                       RowMinHeight="45" />
                    </dxg:GridControl.View>

                    <dxg:GridColumn FieldName="Name" Header="Name (Y)" Width="110" />
                    <dxg:GridColumn FieldName="Attr" Header="Attribute" Width="*" />
                    <dxg:GridColumn Header="Add" Width="60" HorizontalHeaderContentAlignment="Center">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="+"
                                        Style="{StaticResource AddButtonStyle}"
                                        Command="{Binding View.DataContext.AddToTargetCommand}"
                                        CommandParameter="{Binding RowData.Row}" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                </dxg:GridControl>
            </DockPanel>
        </Border>

        <Border Grid.Column="2"
                Background="White"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                CornerRadius="12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.05" />
            </Border.Effect>

            <DockPanel Margin="24">
                <Grid DockPanel.Dock="Top" Margin="0,0,0,16">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center">
                        <Border Width="8"
                                Height="24"
                                Margin="0,0,8,0"
                                Background="#10B981"
                                CornerRadius="2" />
                        <TextBlock Text="Target"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#1E293B" />

                        <Border Margin="16,0,0,0"
                                Padding="4,2"
                                Background="#F1F5F9"
                                CornerRadius="4">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock VerticalAlignment="Center"
                                           FontSize="11"
                                           Foreground="#64748B"
                                           Text="Mode: " />
                                <ComboBox Width="60"
                                          Height="22"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          FontSize="11"
                                          ItemsSource="{Binding ModeOptions}"
                                          SelectedItem="{Binding DimensionMode}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Button HorizontalAlignment="Right"
                            Padding="12,4"
                            Background="#ECFDF5"
                            BorderBrush="#10B981"
                            BorderThickness="1"
                            Command="{Binding AddTargetRowCommand}"
                            Content="+ Row"
                            Foreground="#059669" />
                </Grid>

                <Grid DockPanel.Dock="Bottom" Margin="0,16,0,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="12"
                                 Height="12"
                                 Margin="0,0,8,0"
                                 Fill="#34D399" />
                        <TextBlock FontSize="11" Foreground="#94A3B8" Text="Current Row: " />
                        <TextBlock FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="#475569"
                                   Text="{Binding SelectedTargetRow.No, StringFormat=Group {0}}" />
                        <TextBlock Margin="12,0,0,0"
                                   FontSize="11"
                                   Foreground="#94A3B8"
                                   Text="Current Detail: " />
                        <TextBlock FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="#475569"
                                   Text="{Binding SelectedDetail.RoleLabel}" />
                    </StackPanel>

                    <Button HorizontalAlignment="Right"
                            Padding="20,8"
                            Background="#3B82F6"
                            BorderThickness="0"
                            Command="{Binding SubmitOkCommand}"
                            Content="OK"
                            Foreground="White"
                            FontWeight="Bold" />
                </Grid>

                <dxg:GridControl ItemsSource="{Binding TargetRows}"
                                 CurrentItem="{Binding SelectedTargetRow, Mode=TwoWay}"
                                 ShowBorder="False">
                    <dxg:GridControl.View>
                        <dxg:TableView ShowGroupPanel="False"
                                       AllowEditing="False"
                                       NavigationStyle="Row"
                                       ShowFocusedRectangle="False"
                                       RowStyle="{StaticResource TargetRowStyle}"
                                       HeaderPanelMinHeight="40"
                                       RowMinHeight="110" />
                    </dxg:GridControl.View>

                    <dxg:GridControl.Bands>
                        <dxg:GridControlBand Header=" " HorizontalHeaderContentAlignment="Center">
                            <dxg:GridColumn FieldName="No"
                                            Header="No"
                                            Width="55"
                                            HorizontalHeaderContentAlignment="Center">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontWeight="Bold"
                                                   Foreground="#475569"
                                                   Text="{Binding Value}" />
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                        </dxg:GridControlBand>

                        <dxg:GridControlBand Header=" " HorizontalHeaderContentAlignment="Center">
                            <dxg:GridColumn FieldName="Label" Header="Label" Width="120" />
                        </dxg:GridControlBand>

                        <dxg:GridControlBand Header="Group Info" HorizontalHeaderContentAlignment="Center">
                            <dxg:GridColumn Header="Details" Width="*">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <ItemsControl ItemsSource="{Binding RowData.Row.Details}"
                                                      ItemTemplate="{StaticResource DetailSlotTemplate}" />
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                        </dxg:GridControlBand>

                        <dxg:GridControlBand Header=" " HorizontalHeaderContentAlignment="Center">
                            <dxg:GridColumn FieldName="Color"
                                            Header="State"
                                            Width="100"
                                            HorizontalHeaderContentAlignment="Center">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,4"
                                                Padding="8,4"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                BorderThickness="1"
                                                CornerRadius="4">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Value}" Value="Active">
                                                            <Setter Property="Background" Value="#ECFDF5" />
                                                            <Setter Property="BorderBrush" Value="#10B981" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Value}" Value="Standby">
                                                            <Setter Property="Background" Value="#FFF1F2" />
                                                            <Setter Property="BorderBrush" Value="#F43F5E" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>

                                            <TextBlock FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding Value}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Value}" Value="Active">
                                                                <Setter Property="Foreground" Value="#059669" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Value}" Value="Standby">
                                                                <Setter Property="Foreground" Value="#E11D48" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                        </dxg:GridControlBand>

                        <dxg:GridControlBand Header=" " HorizontalHeaderContentAlignment="Center">
                            <dxg:GridColumn Header="Delete" Width="55" HorizontalHeaderContentAlignment="Center">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Background="Transparent"
                                                BorderThickness="0"
                                                Command="{Binding View.DataContext.DeleteTargetRowCommand}"
                                                CommandParameter="{Binding RowData.Row}"
                                                Content="x"
                                                FontSize="14"
                                                Foreground="#94A3B8"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Foreground" Value="#EF4444" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                        </dxg:GridControlBand>
                    </dxg:GridControl.Bands>
                </dxg:GridControl>
            </DockPanel>
        </Border>
    </Grid>
</Window>
