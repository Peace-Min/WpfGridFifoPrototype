<UserControl x:Class="WpfGridFifoPrototype.Views.TargetGridView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="TargetRowStyle" TargetType="dxg:RowControl">
            <Style.Triggers>
                <DataTrigger Binding="{Binding SelectionState, RelativeSource={RelativeSource Self}}" Value="{x:Static dxg:SelectionState.Focused}">
                    <Setter Property="Background" Value="#F8FAFC" />
                </DataTrigger>
                <DataTrigger Binding="{Binding SelectionState, RelativeSource={RelativeSource Self}}" Value="{x:Static dxg:SelectionState.Selected}">
                    <Setter Property="Background" Value="#F8FAFC" />
                </DataTrigger>
                <DataTrigger Binding="{Binding SelectionState, RelativeSource={RelativeSource Self}}" Value="{x:Static dxg:SelectionState.FocusedAndSelected}">
                    <Setter Property="Background" Value="#F8FAFC" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GroupCellBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding SelectionState, RelativeSource={RelativeSource AncestorType=dxg:RowControl}}" Value="{x:Static dxg:SelectionState.Focused}">
                    <Setter Property="Background" Value="#ECFDF5" />
                    <Setter Property="BorderBrush" Value="#BBF7D0" />
                </DataTrigger>
                <DataTrigger Binding="{Binding SelectionState, RelativeSource={RelativeSource AncestorType=dxg:RowControl}}" Value="{x:Static dxg:SelectionState.Selected}">
                    <Setter Property="Background" Value="#ECFDF5" />
                    <Setter Property="BorderBrush" Value="#BBF7D0" />
                </DataTrigger>
                <DataTrigger Binding="{Binding SelectionState, RelativeSource={RelativeSource AncestorType=dxg:RowControl}}" Value="{x:Static dxg:SelectionState.FocusedAndSelected}">
                    <Setter Property="Background" Value="#ECFDF5" />
                    <Setter Property="BorderBrush" Value="#BBF7D0" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DetailCellBorderStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Opacity" Value="1" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                    <Setter Property="Opacity" Value="0.35" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="#DBEAFE" />
                    <Setter Property="BorderBrush" Value="#2563EB" />
                    <Setter Property="Opacity" Value="1" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TransparentDetailGridCellStyle" TargetType="dxg:LightweightCellEditor">
            <Setter Property="Background" Value="Transparent" />
            <Style.Triggers>
                <Trigger Property="SelectionState" Value="Focused">
                    <Setter Property="Background" Value="Transparent" />
                </Trigger>
                <Trigger Property="SelectionState" Value="Selected">
                    <Setter Property="Background" Value="Transparent" />
                </Trigger>
                <Trigger Property="SelectionState" Value="FocusedAndSelected">
                    <Setter Property="Background" Value="Transparent" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <dxg:GridControl ItemsSource="{Binding TargetRows}"
                         SelectedItem="{Binding SelectedTargetRow, Mode=TwoWay}"
                         ShowBorder="False"
                         VerticalContentAlignment="Center"
                         HorizontalContentAlignment="Center"
                         SelectionMode="Row">
            <dxg:GridControl.View>
                <dxg:TableView AutoWidth="True"
                               ShowGroupPanel="False"
                               IsColumnMenuEnabled="False"
                               VerticalScrollbarVisibility="Auto"
                               AllowCascadeUpdate="False"
                               AllowColumnMoving="False"
                               AllowSorting="False"
                               AllowResizing="False"
                               AllowBandMoving="False"
                               AllowBandResizing="False"
                               ShowIndicator="False"
                               NavigationStyle="Cell"
                               ShowFocusedRectangle="False"
                               RowStyle="{StaticResource TargetRowStyle}" />
            </dxg:GridControl.View>

            <dxg:GridControl.Bands>
                <dxg:GridControlBand Header=" " HorizontalHeaderContentAlignment="Center" OverlayHeaderByChildren="True">
                    <dxg:GridColumn Header="순번" Width="45" HorizontalHeaderContentAlignment="Center">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource GroupCellBorderStyle}">
                                    <dxmvvm:Interaction.Behaviors>
                                        <dxmvvm:EventToCommand EventName="PreviewMouseLeftButtonDown"
                                                               Command="{Binding DataContext.ClearSelectedDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                    </dxmvvm:Interaction.Behaviors>
                                    <TextBlock Text="{Binding RowData.Row.No}" HorizontalAlignment="Center" />
                                </Border>
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                </dxg:GridControlBand>

                <dxg:GridControlBand Header=" " HorizontalHeaderContentAlignment="Center" OverlayHeaderByChildren="True">
                    <dxg:GridColumn Header="그룹명" Width="130" HorizontalHeaderContentAlignment="Center">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource GroupCellBorderStyle}">
                                    <TextBox Text="{Binding RowData.Row.GroupTitle}"
                                             Background="Transparent"
                                             BorderBrush="Transparent"
                                             TextAlignment="Left">
                                        <dxmvvm:Interaction.Behaviors>
                                            <dxmvvm:EventToCommand EventName="PreviewMouseLeftButtonDown"
                                                                   Command="{Binding DataContext.ClearSelectedDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                        </dxmvvm:Interaction.Behaviors>
                                    </TextBox>
                                </Border>
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                </dxg:GridControlBand>

                <dxg:GridControlBand Header="그룹 정보" HorizontalHeaderContentAlignment="Center">
                    <dxg:GridColumn Header="축" ReadOnly="True" AllowEditing="False" Width="90" HorizontalHeaderContentAlignment="Center" CellStyle="{StaticResource TransparentDetailGridCellStyle}">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <ItemsControl ItemsSource="{Binding RowData.Row.Details}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource DetailCellBorderStyle}" Cursor="Hand">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBox Text="{Binding RoleLabel}" IsReadOnly="True" Background="Transparent" BorderBrush="Transparent" Padding="7,3">
                                                        <dxmvvm:Interaction.Behaviors>
                                                            <dxmvvm:EventToCommand EventName="PreviewMouseLeftButtonDown"
                                                                                   Command="{Binding DataContext.SelectDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                                   CommandParameter="{Binding}" />
                                                        </dxmvvm:Interaction.Behaviors>
                                                        <TextBox.Style>
                                                            <Style TargetType="TextBox">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding RoleLabel}" Value="X">
                                                                        <Setter Property="Foreground" Value="#10B981" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding RoleLabel}" Value="Y">
                                                                        <Setter Property="Foreground" Value="#F43F5E" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding RoleLabel}" Value="Z">
                                                                        <Setter Property="Foreground" Value="#FFBB00" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBox.Style>
                                                    </TextBox>
                                                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                                        <Button Width="20"
                                                                Height="20"
                                                                Padding="0"
                                                                Margin="0,0,2,0"
                                                                Visibility="{Binding CanMoveUp, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                Command="{Binding DataContext.MoveDetailUpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}">
                                                            <TextBlock Text="▲" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        </Button>
                                                        <Button Width="20"
                                                                Height="20"
                                                                Padding="0"
                                                                Visibility="{Binding CanMoveDown, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                Command="{Binding DataContext.MoveDetailDownCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}">
                                                            <TextBlock Text="▼" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        </Button>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>

                    <dxg:GridColumn Header="객체명" Width="150" HorizontalHeaderContentAlignment="Center" CellStyle="{StaticResource TransparentDetailGridCellStyle}">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <ItemsControl ItemsSource="{Binding RowData.Row.Details}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource DetailCellBorderStyle}" Cursor="Hand">
                                                <TextBox Text="{Binding ObjectLabel}" Background="Transparent" BorderBrush="Transparent" TextAlignment="Left" IsReadOnly="True">
                                                    <dxmvvm:Interaction.Behaviors>
                                                        <dxmvvm:EventToCommand EventName="PreviewMouseLeftButtonDown"
                                                                               Command="{Binding DataContext.SelectDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                               CommandParameter="{Binding}" />
                                                    </dxmvvm:Interaction.Behaviors>
                                                </TextBox>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>

                    <dxg:GridColumn Header="속성명" Width="150" HorizontalHeaderContentAlignment="Center" CellStyle="{StaticResource TransparentDetailGridCellStyle}">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <ItemsControl ItemsSource="{Binding RowData.Row.Details}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource DetailCellBorderStyle}" Cursor="Hand">
                                                <TextBox Text="{Binding AttributeLabel}" Background="Transparent" BorderBrush="Transparent" TextAlignment="Left" IsReadOnly="True">
                                                    <dxmvvm:Interaction.Behaviors>
                                                        <dxmvvm:EventToCommand EventName="PreviewMouseLeftButtonDown"
                                                                               Command="{Binding DataContext.SelectDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                               CommandParameter="{Binding}" />
                                                    </dxmvvm:Interaction.Behaviors>
                                                </TextBox>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>

                    <dxg:GridColumn Header="단위" Width="120" HorizontalHeaderContentAlignment="Center" CellStyle="{StaticResource TransparentDetailGridCellStyle}">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <ItemsControl ItemsSource="{Binding RowData.Row.Details}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource DetailCellBorderStyle}" Cursor="Hand">
                                                <Grid>
                                                    <TextBlock Text="{Binding DisplayUnit}" Margin="10,0,24,0" VerticalAlignment="Center">
                                                        <dxmvvm:Interaction.Behaviors>
                                                            <dxmvvm:EventToCommand EventName="PreviewMouseLeftButtonDown"
                                                                                   Command="{Binding DataContext.SelectDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                                   CommandParameter="{Binding}" />
                                                        </dxmvvm:Interaction.Behaviors>
                                                    </TextBlock>
                                                    <Button Content="✕"
                                                            Cursor="Hand"
                                                            Margin="0"
                                                            HorizontalAlignment="Right"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Command="{Binding DataContext.RemoveDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}">
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                </dxg:GridControlBand>

                <dxg:GridControlBand Header=" " HorizontalHeaderContentAlignment="Center" OverlayHeaderByChildren="True">
                    <dxg:GridColumn Header="선 그래프 종류" HorizontalHeaderContentAlignment="Center" ReadOnly="True" AllowEditing="False" Width="120">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource GroupCellBorderStyle}">
                                    <ComboBox IsReadOnly="True"
                                              Background="Transparent"
                                              HorizontalContentAlignment="Center"
                                              VerticalContentAlignment="Center"
                                              DisplayMemberPath="Value"
                                              SelectedValuePath="Key"
                                              SelectedValue="{Binding RowData.Row.LineSeriesType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              ItemsSource="{Binding DataContext.LineSeriesTypeList, RelativeSource={RelativeSource AncestorType=dxg:GridControl}}">
                                        <dxmvvm:Interaction.Behaviors>
                                            <dxmvvm:EventToCommand EventName="PreviewMouseLeftButtonDown"
                                                                   Command="{Binding DataContext.ClearSelectedDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                        </dxmvvm:Interaction.Behaviors>
                                    </ComboBox>
                                </Border>
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                </dxg:GridControlBand>

                <dxg:GridControlBand Header=" " HorizontalHeaderContentAlignment="Center" OverlayHeaderByChildren="True">
                    <dxg:GridColumn Header="색상" ReadOnly="True" AllowEditing="False" Width="100" HorizontalHeaderContentAlignment="Center">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource GroupCellBorderStyle}">
                                    <dxe:PopupColorEdit Color="{Binding RowData.Row.Color}">
                                        <dxmvvm:Interaction.Behaviors>
                                            <dxmvvm:EventToCommand EventName="PreviewMouseLeftButtonDown"
                                                                   Command="{Binding DataContext.ClearSelectedDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                        </dxmvvm:Interaction.Behaviors>
                                    </dxe:PopupColorEdit>
                                </Border>
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                </dxg:GridControlBand>
            </dxg:GridControl.Bands>
        </dxg:GridControl>
    </Grid>
</UserControl>
